(edif blinky
  (edifVersion 2 0 0)
  (edifLevel 0)
  (keywordMap (keywordLevel 0))
  (library LIB
    (cell LUT2
      (view NETLIST
        (interface
          (port ADR0)
          (port ADR1)
          (port O))))
    (cell DFFHQ
      (view NETLIST
        (interface
          (port D)
          (port CK)
          (port Q)))))
  (library DESIGN
    (cell blinky
      (view NETLIST
        (interface
          (port a (direction INPUT))
          (port b (direction INPUT))
          (port clk (direction INPUT))
          (port y (direction OUTPUT)))
        (contents
          (instance u_lut
            (viewRef NETLIST (cellRef LUT2 (libraryRef LIB)))
            (property LUT_INIT (integer 8)))
          (instance u_ff
            (viewRef NETLIST (cellRef DFFHQ (libraryRef LIB))))
          (net net_a
            (joined
              (portRef a)
              (portRef ADR0 (instanceRef u_lut))))
          (net net_b
            (joined
              (portRef b)
              (portRef ADR1 (instanceRef u_lut))))
          (net net_clk
            (joined
              (portRef clk)
              (portRef CK (instanceRef u_ff))))
          (net net_comb
            (joined
              (portRef O (instanceRef u_lut))
              (portRef D (instanceRef u_ff))))
          (net net_y
            (joined
              (portRef Q (instanceRef u_ff))
              (portRef y))))))))
